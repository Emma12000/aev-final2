{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter @aev/backend run db:generate && pnpm --filter @aev/backend build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @aev/backend run db:migrate:deploy && pnpm --filter @aev/backend start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

# ══════════════════════════════════════════════════════════
# VARIABLES D'ENVIRONNEMENT — Association Espoir & Vie
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS commiter le fichier .env
# ══════════════════════════════════════════════════════════

# ── Base de données (Railway PostgreSQL) ──────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── JWT (clés RS256 — générer avec: openssl genrsa -out private.pem 2048) ─
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Supabase Storage ───────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_BUCKET="aev-documents"

# ── Application ────────────────────────────────────────────
NODE_ENV="production"
PORT=3001
APP_URL="https://archive.espoiretvie.td"
CORS_ORIGIN="https://archive.espoiretvie.td"

# ── Email (Resend ou SMTP) ─────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="no-reply@espoiretvie.td"

# ── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
